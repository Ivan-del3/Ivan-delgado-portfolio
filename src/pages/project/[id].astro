---
export const prerender = true;
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(r => ({
    params: { id: r.slug }
  }));
}

const { id } = Astro.params;
const projects = await getCollection("projects");
const project = projects.find(r => r.slug === id);

if (!project) {
  throw new Error(`Proyecto no encontrado: ${id}`);
}

const { data } = project;
const { title, img, sections, repository, link } = data;
---

<Layout>
  <section id="project" class="px-6">

    <!-- Back link -->
    <a href="/portafolio" class="back-link">
      <span class="text-2xl leading-none">←</span>
      <span class="text-sm md:text-base">Volver a los proyectos</span>
    </a>

    <!-- Título principal -->
    <h1 class="box-general-title md:text-5xl text-center text-[#f0ece9] mb-20">
      {title}
    </h1>

    <!-- Secciones -->
    <div class="flex flex-col">

      {sections?.map((section, index) => {
        const image = index === 0 ? img : section.img;
        const last = index === sections.length - 1;

        return (
          <div>
            <section class="section-grid">

            {image && (
                <div class="section-image order-2 lg:order-1">
                  <img src={`/${image}`} alt={section.title} class="img-project" />
                </div>
              )}

              <div class={`space-y-6 order-1 
                ${image 
                  ? 'lg:col-span-5 lg:order-2'
                  : 'lg:col-span-full'
                }`}>

                <h2 class={`${image ? 'section-title' : 'section-title text-center'}`}>{section.title}</h2>

                {section.text && (
                    <div 
                      class="section-text" 
                      set:html={
                        section.text
                              // Resaltar código entre comillas simples
                              .replace(/'(.*?)'/g, '<code class="code-highlight">$1</code>')
                              
                              // Detectar listas con guiones (- )
                              // Busca el inicio de línea, el guion y captura el resto.
                              .replace(/^(?:\s*)-\s+(.*)/gm, '<span class="list-bullet">$1</span>')
                              
                              // Detectar listas numeradas (1. , 2. , etc)
                              .replace(/^(?:\s*)(\d+\.)\s+(.*)/gm, '<span class="list-item-number list-number" data-number="$1">$2</span>')
                      }
                    />
                )}
              </div>

            </section>

            {!last && (
              <div class="separator">
                <div class="separator-line"></div>
                <div class="separator-space"></div>
                <div class="separator-line"></div>
              </div>
            )}

          </div>
        );
      })}

    </div>
    <div class="project-links-container">
      <h3 class="links-title">¿Quieres saber más?</h3>
      <div class="links-grid">
        {repository && (
          <a href={repository} target="_blank" class="link-card">
            <span class="link-icon">GitHub</span>
            <div class="link-content">
              <span class="link-label">Repositorio</span>
              <span class="link-url">Ver código fuente →</span>
            </div>
          </a>
        )}
        
        {link && (
          <a href={link} target="_blank" class="link-card highlight">
            <span class="link-icon">Web</span>
            <div class="link-content">
              <span class="link-label">Proyecto</span>
              <span class="link-url">Visitar el sitio →</span>
            </div>
          </a>
        )}
      </div>
    </div>

  </section>
</Layout>
