---
import "../styles/global.css";
import PdfButton from '../components/PdfButton.jsx';
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CV Iván Delgado</title>
</head>
<body class="cv-body-wrapper">
  <div class="cv-main-container">
    
    <div id="cv-pdf" class="cv-paper">
      <aside class="sidebar">
        <img src="/personal-image.png" alt="Foto Iván Delgado" class="profile-img">
        <h1 class="name">Iván Delgado</h1>
        <p class="role">Desarrollador de software</p>

        <div class="sidebar-section">
          <h2 class="sidebar-title">Contacto</h2>
          <p class="sidebar-text">Email: ivandelgado31298@gmail.com</p>
          <p class="sidebar-text">Tel: (+34) 697 98 91 16</p>
        </div>

        <div class="sidebar-section">
          <h2 class="sidebar-title">Idiomas</h2>
          <ul class="sidebar-list">
            <li>Español - Nativo</li>
            <li>Inglés - B2</li>
          </ul>
        </div>

        <div class="sidebar-section">
          <h2 class="sidebar-title">Habilidades</h2>
          <ul class="sidebar-list">
            <li>HTML, CSS, Tailwind</li>
            <li>JavaScript / TypeScript</li>
            <li>React / Astro</li>
            <li>Git y control de versiones</li>
          </ul>
        </div>
      </aside>

      <main class="main-content">
        <section class="content-section">
          <h2 class="section-title">Perfil Profesional</h2>
          <p class="description">
            Desarrollador web con experiencia en frontend y diseño de interfaces modernas. 
            Apasionado por crear soluciones intuitivas y eficientes.
          </p>
        </section>

        <section class="content-section">
          <h2 class="section-title">Experiencia Profesional</h2>
          <div class="experience-item">
            <h3 class="company-name">Mantenimiento Informático Paterna S.L.</h3>
            <ul class="experience-list">
              <li>Desarrollador (Marzo 2025 - Junio 2025)</li>
              <li>Desarrollador (Noviembre 2025 - Febrero 2026)</li>
            </ul>
          </div>
        </section>

        <section class="content-section">
          <h2 class="section-title">Formación Académica</h2>
          <div class="education-item">
            <p><strong>CF Desarrollo de Aplicaciones Web</strong></p>
            <p>CEAC FP OFICIAL (2024 - 2026)</p>
          </div>
        </section>
      </main>
    </div>

    <PdfButton client:only="react" targetId="cv-pdf" filename="CV-Ivan-Delgado.pdf"/>
  </div>
</body>
</html>