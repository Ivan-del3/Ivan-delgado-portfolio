---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
  <section class="max-w-7xl mx-auto px-6 pb-12">
    <div class="flex justify-center mb-16">
      <h1 class="projects-title">Blog</h1>
    </div>

    <div class="space-y-12">
      {blogPosts.map((post) => {
        const { slug, data } = post;
        return (
          <a href={`/post/${slug}`} class="flex flex-col md:flex-row items-center bg-[#f0ece9] rounded-2xl overflow-hidden group hover:shadow-2xl transition-all duration-300">
            {/* Imagen a la izquierda */}
            <div class="w-full md:w-1/3 aspect-video overflow-hidden">
              <img 
                src={`/${data.img}`} 
                alt={data.title} 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
              />
            </div>
            {/* Texto a la derecha */}
            <div class="w-full md:w-2/3 p-8 flex flex-col justify-center">
              <h2 class="text-2xl md:text-3xl font-serif text-[#22233A] mb-4">
                {data.title}
              </h2>
              <p class="text-[#2b2b2b] text-base md:text-lg line-clamp-3">
                {data.description}
              </p>
              <span class="mt-4 text-[#6366F1] font-bold">Leer más →</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>