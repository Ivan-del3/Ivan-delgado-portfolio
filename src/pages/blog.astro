---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  
---

<Layout>
  <section class="max-w-7xl mx-auto px-6 pb-12">
    <div class="flex justify-center">
      <h1 class="projects-title">Blog</h1>
    </div>

      {blogPosts.map((post) => {
        const { slug, data } = post;
        const tags = data.tags;
        return (
          <div class="flex flex-col md:flex-row items-center bg-[#f0ece9] rounded-2xl mb-16  overflow-hidden transition-all duration-300">
            <div class="w-full md:w-1/3 aspect-video overflow-hidden">
              <img 
                src={`/${data.img}`} 
                alt={data.title} 
                class="w-full h-full object-cover md:pl-4" 
              />
            </div>

            <div class="w-full md:w-2/3 p-8 flex flex-col justify-center">
              <h2 class="text-2xl md:text-3xl font-serif text-[#22233A] mb-4">
                {data.title}
              </h2>

              <p class="text-[#2b2b2b] mb-3 text-base md:text-lg">
                {data.description}
              </p>
              <div class="flex flex-row gap-2 mb-3 flex-wrap">
                {tags?.map((tag) => {
                  return(
                    <p class="mr-2 px-3 py-1 bg-[#6366F1]/20 rounded-full font-semibold">{tag}</p>
                  )
                })}
              </div>
              <p class="text-sm md:text-base italic">{data.date.toLocaleDateString()}</p>

              <a href={`/post/${slug}`} class="inline-block mt-4 text-[#6366F1] font-bold hover:translate-x-2 duration-500"> 
                  Leer más <span class="text-lg inline-block translate-y-[1px]">→</span>
              </a>
              
            </div>
          </div>
        );
      })}
  </section>
</Layout>