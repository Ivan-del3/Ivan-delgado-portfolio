---
export const prerender = true;
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map(r => ({
    params: { id: r.slug }
  }));
}

const { id } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find(r => r.slug === id);

if (!post) throw new Error(`Post no encontrado: ${id}`);

const { title, img, sections, repository, link } = post.data;
---

<Layout>
  <section class="max-w-7xl mx-auto px-6">
    <a href="/blog" class="back-link">
      <span class="text-2xl leading-none">←</span>
      <span>Volver al blog</span>
    </a>

    <h1 class="box-general-title text-2xl sm:text-3xl md:text-4xl lg:text-5xl text-center text-[#f0ece9] leading-snug">
      {title}
    </h1>

    <div class="flex flex-col">
      {sections?.map((section, index) => {
        const image = section.img || (index === 0 ? img : null);
        const last = index === sections.length - 1;
        const firstSection = index === 0;
        return (
          <div class="flex flex-col items-center w-full max-w-4xl mx-auto mb-14">
            {firstSection && (
              <div class="w-full flex justify-center mb-16">
                <img src={`/${image}`} alt={section.title} class="post-image-first" />
              </div>              
            )}
            
            <div class="w-full text-left mb-6">
              <h2 class="post-title">{section.title}</h2>
            </div>
            
            {section.text && (
              <div class="w-full text-left">
                <div 
                  class="post-text" 
                  set:html={
                    section.text
                          // Resaltar código entre comillas simples
                          .replace(/'(.*?)'/g, '<code class="code-highlight">$1</code>')
                          
                          // Detectar listas con guiones (- )
                          // Busca el inicio de línea, el guion y captura el resto.
                          .replace(/^(?:\s*)-\s+(.*)/gm, '<span class="list-bullet">$1</span>')
                          
                          // Detectar listas numeradas (1. , 2. , etc)
                          .replace(/^(?:\s*)(\d+\.)\s+(.*)/gm, '<span class="list-item-number list-number" data-number="$1">$2</span>')
                  }
                />
              </div>
            )}
            
            {image && !firstSection && (
              <div class="w-full flex justify-center mb-6">
                <img src={`/${image}`} alt={section.title} class="post-image-first post-image" />
              </div>
            )}

            {!last && (
              <div class="separator w-full mt-12 mb-0">
                <div class="separator-line"></div>
                <div class="separator-space"></div>
                <div class="separator-line"></div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="post-links-container">
      <h3 class="links-title">¿Te interesa ver el código?</h3>
      <div class="links-grid">
        {repository && (
          <a href={repository} target="_blank" class="link-card">
            <span class="link-icon">GitHub</span>
            <div class="link-content">
              <span class="link-label">Repositorio</span>
              <span class="link-url">Ver el código →</span>
            </div>
          </a>
        )}
        {link && (
          <a href={link} target="_blank" class="link-card highlight">
            <span class="link-icon">Web</span>
            <div class="link-content">
              <span class="link-label">Demo</span>
              <span class="link-url">Visitar el sitio →</span>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>