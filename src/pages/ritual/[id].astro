---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const rituales = await getCollection("rituales");
  return rituales.map(r => ({
    params: { id: r.slug }
  }));
}

const { id } = Astro.params;
const rituales = await getCollection("rituales");
const ritual = rituales.find(r => r.slug === id);

if (!ritual) {
  throw new Error(`Ritual no encontrado: ${id}`);
}

const { data } = ritual;
const { titulo, img, secciones } = data;
---

<Layout>
  <section class="max-w-6xl mx-auto px-6">

    <!-- Back link -->
    <a href="/#rituales" class="back-link">
      <span class="text-2xl leading-none">←</span>
      <span class="text-sm md:text-base">Volver a las triadas</span>
    </a>

    <!-- Título principal -->
    <h1 class="box-general-title md:text-5xl text-center text-[#9f2f4a] mb-20">
      {titulo}
    </h1>

    <!-- Secciones -->
    <div class="flex flex-col">

      {secciones?.map((seccion, index) => {
        const imagen = index === 0 ? img : seccion.img;
        const esUltima = index === secciones.length - 1;

        return (
          <div>
            <section class="section-grid">

              <div class="section-image">
                <img src={`/${imagen}`} alt={seccion.titulo} class="img-standard max-h-[520px]" />
              </div>

              <div class="space-y-6 text-[#2b2b2b]">
                <h2 class="section-title">{seccion.titulo}</h2>
                <p class="section-text">{seccion.texto}</p>
              </div>

            </section>

            {!esUltima && (
              <div class="separator">
                <div class="separator-line"></div>
                <div class="separator-space"></div>
                <div class="separator-line"></div>
              </div>
            )}

          </div>
        );
      })}

    </div>
  </section>
</Layout>
