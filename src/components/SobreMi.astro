<section id="sobre-mi" class="mt-6">
<div class="box-style scroll-section">
  <div class="sobre-layout">
    <div class="sobre-img">
      <img
        src="/personal-image.png"
        alt="Ivan Delgado"
        class="personal-image"
      />
    </div>
    <div class="sobre-text box-text space-y-4">
      <h2 class="box-general-title">Iván Delgado Alcobenda</h2>
      <p>
        Soy Técnico Superior en Desarrollo de Aplicaciones Web, y siempre me llamó la atención Internet y Pokémon. Por casualidad me topé con C++ y me pareció muy curioso porque entendí que todo aquello que había estado viendo desde pequeño cobraba sentido. En ese momento entendí que programando podía llegar a crear cualquier tipo de experiencia para otras personas, así que decidí dedicarme al desarrollo de software.
      </p>
      <p>
        Además hay algo en esta profesión que encaja mucho con mi forma de ver la vida. Resolver problemas de manera eficiente, adaptarme constantemente y utilizar las herramientas que tengo de la mejor manera posible para lograr mis objetivos.
      </p>
      <p>
        Esa mentalidad la apliqué cuando me planteé construir un marketplace full-stack: WebSockets, sistema de escrow con transacciones atómicas y despliegue completo con Docker. Elegí Laravel y React porque de las herramientas que tenía en ese momento, estas eran las que encajaban exactamente con lo que quería construir. Pero no estoy enfocado en un lenguaje ni un stack en concreto, mi enfoque está en entender el problema y elegir la mejor herramienta que disponga en ese momento.
      </p>
      <p>
        Mi objetivo es seguir formándome y creciendo para ayudar a mi equipo de desarrollo con las herramientas que traigo y construir soluciones que se adapten a las necesidades de los clientes.
      </p>
      <a href="/cv" target="_blank" class="cv-btn">
        Ver CV
      </a>
    </div>
  </div>
</div>

<div class="separator">
  <div class="separator-line"></div>
  <div class="separator-space"></div>
  <div class="separator-line"></div>
</div>

<div class="skills-outer mb-16 sm:mb-24 md:mb-32">
  <h2 class="skills-heading">Habilidades</h2>

  <div class="skills-grid">
    <div class="skill-col from-left">
      <div class="skill-card">
        <span class="skill-cat">Frontend</span>
        <div class="skill-tags">
          <span>HTML</span><span>CSS</span><span>JavaScript</span>
          <span>TypeScript</span><span>React</span><span>Astro</span><span>Tailwind</span>
        </div>
      </div>
      <div class="skill-card">
        <span class="skill-cat">Backend</span>
        <div class="skill-tags">
          <span>Java</span><span>PHP</span><span>Laravel</span><span>Filament</span>
        </div>
      </div>
    </div>

    <div class="skill-col from-right">
      <div class="skill-card">
        <span class="skill-cat">Herramientas</span>
        <div class="skill-tags">
          <span>Git</span><span>GitHub</span><span>Docker</span>
          <span>Ubuntu Server</span><span>Ollama</span><span>Fine-tuning LLM</span>
        </div>
      </div>
      <div class="skill-card">
        <span class="skill-cat">Bases de datos</span>
        <div class="skill-tags">
          <span>MySQL</span><span>PL/SQL</span><span>MongoDB</span>
        </div>
      </div>
    </div>
  </div>
</div>
</section>

<script>
  function initSkillsReveal() {
    const cols = document.querySelectorAll('.skill-col');
    if (!cols.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(({ target, isIntersecting }) => {
          if (isIntersecting) {
            target.classList.add('revealed');
            observer.unobserve(target);
          }
        });
      },
      { threshold: 0.15 }
    );
    cols.forEach(col => observer.observe(col));
  }

  document.addEventListener('astro:page-load', initSkillsReveal);
  initSkillsReveal();
</script>