---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import DropdownMenu from '../components/DropdownMenu.jsx';
import IconEmail from '../components/icons/IconEmail.astro';
import IconWhatsApp from '../components/icons/IconWhatsApp.astro';
import IconLinkedIn from '../components/icons/IconLinkedIn.astro';
import IconGitHub from '../components/icons/IconGitHub.astro';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Mi Portafolio</title>
    <ClientRouter />
  </head>

  <body class="flex flex-col min-h-screen global-style">

    <header class="header-style">
      <div class="header-container">

        <div class="logo">
          <a href="/">
            <img
              src="/marca-personal.png"
              alt="Iván Delgado - Marca Personal"
              class="img-logo"
            />
          </a>
        </div>

        <DropdownMenu client:visible/>

        <nav id="menu" class="nav-main hidden md:flex">
          <a href="/#sobre-mi" class="nav-link">Sobre mí</a>
          <a href="/#portafolio" class="nav-link">Portafolio</a>
          <a href="/#blog" class="nav-link">Blog</a>
          <a href="/cv" class="nav-link" target="_blank">CV</a>
          <a href="/#contacto" class="nav-link">Contacto</a>
        </nav>
      </div>
    </header>

    <main class="main-container flex-1 w-full">
      <slot />
    </main>

    <footer id="contacto" class="site-footer scroll-section">
      <p class="footer-tagline">¿Hablamos?</p>
      <div class="flex justify-center gap-4 my-8">
        <a href="mailto:ivandelgado31298@gmail.com" class="footer-icon-btn" title="Email">
          <IconEmail class="w-6 h-6" />
        </a>
        <a href="https://wa.me/34XXXXXXXXX" target="_blank" class="footer-icon-btn" title="WhatsApp">
          <IconWhatsApp class="w-6 h-6" />
        </a>
        <a href="https://www.linkedin.com/in/iv%C3%A1n-delgado-alcobenda-2949713b8/" target="_blank" class="footer-icon-btn" title="LinkedIn">
          <IconLinkedIn class="w-6 h-6" />
        </a>
        <a href="https://github.com/Ivan-del3" target="_blank" class="footer-icon-btn" title="GitHub">
          <IconGitHub class="w-6 h-6" />
        </a>
      </div>
      <p class="footer-copy">© 2026 Iván Delgado · Todos los derechos reservados</p>
    </footer>

  </body>
</html>