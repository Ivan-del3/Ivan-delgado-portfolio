---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import DropdownMenu from '../components/DropdownMenu.jsx';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <script is:inline>
      if (performance?.getEntriesByType('navigation')[0]?.type === 'reload') {
        if (location.pathname !== '/' || location.hash) location.replace('/');
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Mi Portafolio</title>
    <ClientRouter />
  </head>

  <body class="flex flex-col min-h-screen global-style">

    <header class="header-style">
      <div class="header-container">

        <div class="logo">
          <a href="/">
            <img
              src="/marca-personal.png"
              alt="Iván Delgado - Marca Personal"
              class="img-logo"
            />
          </a>
        </div>

        <DropdownMenu client:visible/>

        <nav id="menu" class="nav-main hidden md:flex">
          <a href="/#sobre-mi" class="nav-link">Sobre mí</a>
          <a href="/#portafolio" class="nav-link">Portafolio</a>
          <a href="/#blog" class="nav-link">Blog</a>
          <a href="/cv" class="nav-link" target="_blank">CV</a>
          <a href="/#contacto" class="nav-link">Contacto</a>
        </nav>
      </div>
    </header>

    <main class="main-container flex-1 w-full">
      <slot />
    </main>

    <slot name="footer" />

  </body>

  <script is:inline>
    function initEffects() {
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(({ target, isIntersecting }) => {
          if (isIntersecting) {
            target.classList.add('revealed');
            revealObserver.unobserve(target);
          }
        });
      }, { threshold: 0.07, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('main section, main .separator').forEach(el => {
        revealObserver.observe(el);
      });
    }

    document.addEventListener('astro:page-load', initEffects);
    initEffects();
  </script>

</html>

