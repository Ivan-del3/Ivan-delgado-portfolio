---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <script is:inline>
      if (performance?.getEntriesByType('navigation')[0]?.type === 'reload') {
        if (location.pathname !== '/' || location.hash) location.replace('/');
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Iván Delgado</title>
    <ClientRouter />
  </head>

  <body class="flex flex-col min-h-screen global-style">

    <header class="fixed top-0 z-50 flex items-center justify-center w-full mt-2">
      <nav id="menu" class="nav-main">
        <a href="/#sobre-mi" aria-label="sobre-mi" class="nav-link">Sobre mí</a>
        <a href="/#proyectos" aria-label="proyectos" class="nav-link">Proyectos</a>
        <a href="/#blog" aria-label="blog" class="nav-link">Blog</a>
        <a href="/#contacto" aria-label="contacto" class="nav-link">Contacto</a>
      </nav>
    </header>

    <main class="main-container flex-1 w-full">
      <slot />
    </main>

    <slot name="footer" />

  </body>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const nav = document.querySelector("header nav");
      if (!nav) return;

      const updateNav = () => {
        const atTop = window.scrollY < 10;
        nav.style.background     = atTop ? "transparent" : "";
        nav.style.borderColor    = atTop ? "transparent" : "";
        nav.style.boxShadow      = atTop ? "none"        : "";
        nav.style.backdropFilter = atTop ? "none"        : "";
      };

      updateNav();
      window.addEventListener("scroll", updateNav, { passive: true });
    });
  </script>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const navLinks = document.querySelectorAll("header nav a");
      const sectionIds = Array.from(navLinks)
        .map(l => l.getAttribute("aria-label"))
        .filter(Boolean);

      const setActive = (id) => {
        navLinks.forEach(link => {
          const isActive = link.getAttribute("aria-label") === id;
          link.classList.toggle("text-indigo-300", isActive);
          link.classList.toggle("bg-indigo-500/30", isActive);
          link.classList.toggle("border", isActive);
          link.classList.toggle("border-indigo-400/40", isActive);
          link.classList.toggle("text-white/90", !isActive);
        });
      };

      navLinks.forEach(link => {
        link.addEventListener("click", () => setActive(link.getAttribute("aria-label")));
      });

      const isHome = window.location.pathname === "/";
      if (!isHome) return;

      const update = () => {
        const atBottom = window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 5;
        if (atBottom) {
          setActive(sectionIds[sectionIds.length - 1]);
          return;
        }

        const triggerY = window.scrollY + window.innerHeight * 0.35;
        let activeId = sectionIds[0];
        for (const id of sectionIds) {
          const el = document.getElementById(id);
          if (!el) continue;
          if (el.getBoundingClientRect().top + window.scrollY <= triggerY) activeId = id;
        }
        setActive(activeId);
      };

      let ticking = false;
      window.addEventListener("scroll", () => {
        if (!ticking) {
          requestAnimationFrame(() => { update(); ticking = false; });
          ticking = true;
        }
      }, { passive: true });

      const hash = window.location.hash.slice(1);
      if (hash && sectionIds.includes(hash)) {
        setActive(hash);
        const target = document.getElementById(hash);
        if (target) setTimeout(() => target.scrollIntoView({ behavior: "smooth" }), 50);
      } else {
        update();
      }
    });
  </script>

  <script is:inline>
    function initReveal() {
      if (window.__revealObs) window.__revealObs.disconnect();

      window.__revealObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            window.__revealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.07, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('main section, main .separator').forEach(function(el) {
        window.__revealObs.observe(el);
      });
    }

    if (!window.__revealListenerAdded) {
      window.__revealListenerAdded = true;
      document.addEventListener('astro:page-load', initReveal);
    }
  </script>

</html>

